{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_MANIFEST_MODE": "ON",
                "VCPKG_INSTALLED_DIR": "${sourceDir}/build/${presetName}_vcpkg_installed"
            }
        },
        {
            "name": "ucrt-base",
            "hidden": true,
            "inherits": "base",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic",
                "VCPKG_DEFAULT_TRIPLET": "x64-mingw-dynamic",
                "VCPKG_HOST_TRIPLET": "x64-mingw-dynamic",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_MAKE_PROGRAM": "ninja"
            }
        },
        {
            "name": "linux-base",
            "hidden": true,
            "inherits": "base",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-linux",
                "VCPKG_DEFAULT_TRIPLET": "x64-linux",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        { "name": "win-debug", "inherits": "ucrt-base", "hidden": true, "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" } },
        { "name": "win-release", "inherits": "ucrt-base", "hidden": true, "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" } },
        { "name": "linux-debug", "inherits": "linux-base", "hidden": true, "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" } },
        { "name": "linux-release", "inherits": "linux-base", "hidden": true, "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" } }
    ]
}
